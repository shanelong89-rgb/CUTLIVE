{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/cultive/dist/public",
  "framework": null,
  "functions": {
    "api/event/[slug].js": {
      "includeFiles": "artifacts/cultive/dist/public/index.html"
    }
  },
  "redirects": [
    { "source": "/partnerships.html", "destination": "/partnerships", "permanent": true }
  ],
  "rewrites": [
    { "source": "/event/:slug", "destination": "/api/event/:slug" },
    { "source": "/partnerships",  "destination": "/partnerships.html" },
    { "source": "/(.*)",          "destination": "/index.html" }
  ]
}
