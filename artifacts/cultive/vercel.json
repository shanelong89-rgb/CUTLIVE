{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/event/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(twitterbot|facebookexternalhit|facebot|linkedinbot|slackbot|WhatsApp|TelegramBot|Discordbot|Applebot|ia_archiver|Pinterest|redditbot|Slurp|bingbot|Googlebot).*"
        }
      ],
      "destination": "/api/event/:id"
    }
  ]
}
