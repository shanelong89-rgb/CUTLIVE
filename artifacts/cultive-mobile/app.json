{
  "expo": {
    "name": "CULTIVE",
    "slug": "figmamy-make-file",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cultive",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "city.cultive.app",
      "appleTeamId": "QU9S49M4Y6",
      "associatedDomains": ["applinks:cultive.city", "webcredentials:cultive.city"],
      "infoPlist": {
        "NSCalendarsUsageDescription": "CULTIVE saves events to your calendar so you don't miss them.",
        "NSCalendarsFullAccessUsageDescription": "CULTIVE saves events to your calendar so you don't miss them.",
        "NSRemindersUsageDescription": "CULTIVE uses reminders to notify you about upcoming events.",
        "NSCameraUsageDescription": "CULTIVE uses your camera to add a photo when submitting an event.",
        "NSPhotoLibraryUsageDescription": "CULTIVE accesses your photo library to add an image when submitting an event.",
        "NSPhotoLibraryAddUsageDescription": "CULTIVE may save event photos to your photo library."
      }
    },
    "android": {
      "package": "city.cultive.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "cultive.city"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://cultive.city"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "CULTIVE saves events to your calendar so you don't miss them."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#000000",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ee7a544c-33b6-432b-b6e5-3dcb416879de"
      }
    }
  }
}
