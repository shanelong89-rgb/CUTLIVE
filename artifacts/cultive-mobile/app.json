{
  "expo": {
    "name": "CULTIVE",
    "slug": "cultive-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cultive",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.replit.cultivemobile",
      "infoPlist": {
        "NSCalendarsUsageDescription": "CULTIVE saves events to your calendar so you don't miss them.",
        "NSCalendarsFullAccessUsageDescription": "CULTIVE saves events to your calendar so you don't miss them.",
        "NSRemindersUsageDescription": "CULTIVE uses reminders to notify you about upcoming events."
      }
    },
    "android": {
      "package": "com.replit.cultivemobile"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "CULTIVE saves events to your calendar so you don't miss them."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#000000",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
